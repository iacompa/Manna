{
  "name": "mobile-store",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@manna/ui": "workspace:*",
    "@manna/scripture": "workspace:*",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "expo": "~57.0.4",
    "expo-asset": "~12.0.0",
    "expo-constants": "^57.0.3",
    "expo-linking": "^57.0.2",
    "expo-router": "^57.0.4",
    "expo-sqlite": "^57.0.0",
    "expo-status-bar": "~57.0.0",
    "i18next": "^26.3.6",
    "react": "19.2.3",
    "react-i18next": "^17.0.9",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.26.0",
    "@manna/scripture": "workspace:*",
    "expo-asset": "~12.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform ios --output-dir dist || mkdir -p dist",
    "lint": "echo \"mobile-store: lint stub\"",
    "sync-corpus": "mkdir -p assets && cp ../../packages/scripture/assets/scripture.db assets/scripture.db",
    "pretypecheck": "pnpm sync-corpus",
    "typecheck": "tsc --noEmit",
    "dev": "expo start"
  },
  "private": true
}
