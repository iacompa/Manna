# Manna monorepo — copy to .env.local (never commit secrets)

# --- Mobile store (public) ---
EXPO_PUBLIC_ENABLE_BYOK=false
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=your_revenuecat_public_sdk_key_ios
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=your_revenuecat_public_sdk_key_android

# --- Supabase Edge / server (secrets — Supabase dashboard or local supabase secrets) ---
# SUPABASE_SERVICE_ROLE_KEY=never_in_mobile_binary
# GEMINI_API_KEY=server_only_gemini_key_for_plus_ai
# REVENUECAT_WEBHOOK_SECRET=server_only
# MANNA_AI_GLOBAL_SPEND_BREAKER_USD=optional_ops_limit

# Plus model lock (documentation only — not a client env var)
# MANNA_PLUS_MODEL_ID=gemini-2.5-flash-lite
